[
  {
    "label": "Run photo-sorter Debug Binary",
    "build": {
      "command": "bash",
      "args": ["$ZED_WORKTREE_ROOT/build.sh", "Debug"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/build/Debug/photo_sorter",
    "request": "launch",
    "adapter": "CodeLLDB",
    "env": {
      "SDL_VIDEODRIVER": "wayland",
    },
  },
  {
    "label": "Run photo-sorter Release Binary",
    "build": {
      "command": "bash",
      "args": ["$ZED_WORKTREE_ROOT/build.sh", "Release"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/build/Release/photo_sorter",
    "request": "launch",
    "adapter": "CodeLLDB",
    "env": {
      "SDL_VIDEODRIVER": "wayland",
    },
  },
  {
    "label": "Run raw-viewer Debug Binary",
    "build": {
      "command": "bash",
      "args": ["$ZED_WORKTREE_ROOT/build.sh", "Debug"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/build/Debug/raw_viewer",
    "request": "launch",
    "adapter": "CodeLLDB",
    "env": {
      "SDL_VIDEODRIVER": "wayland",
    },
  },
]
